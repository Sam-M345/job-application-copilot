# Copy repo root .env or set here. Copilot reads ANTHROPIC_API_KEY from repo root .env first.
ANTHROPIC_API_KEY=your_key_here
ANTHROPIC_MODEL=claude-sonnet-4-6

# Optional LangSmith tracing (not required for local run)
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=
# LANGCHAIN_PROJECT=job-application-intelligence-copilot
